#include <iostream>
using namespace std;

int heap[100];
int size = 0;

void insert(int value) {
    size++;
    int i = size;

    // Insert at end and heapify up
    while (i > 1 && heap[i / 2] > value) {
        heap[i] = heap[i / 2];
        i = i / 2;
    }
    heap[i] = value;
}

void display() {
    for (int i = 1; i <= size; i++)
        cout << heap[i] << " ";
}

int main() {
    insert(50);
    insert(30);
    insert(40);
    insert(10);
    insert(5);
    insert(20);

    cout << "Min Heap: ";
    display();

    return 0;
}
