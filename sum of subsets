#include <iostream>
using namespace std;

int w[20], x[20];   // w = weights, x = solution vector
int n, target;

void sumOfSubsets(int s, int k, int r) {
    x[k] = 1;

    if (s + w[k] == target) {
        // Print subset
        cout << "Subset: ";
        for (int i = 0; i <= k; i++) {
            if (x[i] == 1)
                cout << w[i] << " ";
        }
        cout << endl;
    }
    else if (s + w[k] + w[k+1] <= target) {
        sumOfSubsets(s + w[k], k + 1, r - w[k]);
    }

    if ((s + r - w[k] >= target) && (s + w[k+1] <= target)) {
        x[k] = 0;
        sumOfSubsets(s, k + 1, r - w[k]);
    }
}

int main() {
    int total = 0;

    cout << "Enter number of elements: ";
    cin >> n;

    cout << "Enter elements (in increasing order): ";
    for (int i = 0; i < n; i++) {
        cin >> w[i];
        total += w[i];
    }

    cout << "Enter target sum: ";
    cin >> target;

    sumOfSubsets(0, 0, total);

    return 0;
}
