#include <iostream>
using namespace std;

int josephus(int n, int k) {
    if (n == 1)
        return 0;
    return (josephus(n - 1, k) + k) % n;
}

int main() {
    int n = 7, k = 3;

    int safePos = josephus(n, k) + 1; // convert to 1-based index

    cout << "Safe position: " << safePos;

    return 0;
}
