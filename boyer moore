#include <iostream>
#include <cstring>
using namespace std;

#define MAX 256

// Build bad character table
void badCharHeuristic(string pat, int size, int badchar[]) {
    for (int i = 0; i < MAX; i++)
        badchar[i] = -1;

    for (int i = 0; i < size; i++)
        badchar[(int)pat[i]] = i;
}

// Boyer Moore search
void search(string txt, string pat) {
    int m = pat.size();
    int n = txt.size();

    int badchar[MAX];
    badCharHeuristic(pat, m, badchar);

    int s = 0; // shift of pattern

    while (s <= (n - m)) {
        int j = m - 1;

        while (j >= 0 && pat[j] == txt[s + j])
            j--;

        if (j < 0) {
            cout << "Pattern found at index " << s << endl;
            s += (s + m < n) ? m - badchar[txt[s + m]] : 1;
        } else {
            s += max(1, j - badchar[txt[s + j]]);
        }
    }
}

int main() {
    string txt = "ABAAABCD";
    string pat = "ABC";

    search(txt, pat);

    return 0;
}
